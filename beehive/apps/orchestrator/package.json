    "pm2:status": "pm2 status hive-orchestrator"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.0",
    "pm2": "^5.4.3",
    "typescript": "^5.8.3"
  }
}
