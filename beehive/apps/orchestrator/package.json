{
  "name": "hive-orchestrator",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check:types": "tsc --noEmit -p tsconfig.json",
    "start": "node dist/index.js",
