{
  "name": "hive-framework-sidecar",
  "version": "1.0.0",
  "private": true,
  "description": "Runtime isolado do Hive Framework",
  "type": "commonjs",
  "scripts": {
    "hive": "bash \"$BEEHIVE_PATH/bin/hive.sh\"",
    "hive:inbox": "npm run hive -- inbox",
    "hive:status": "npm run hive -- status",
    "hive:lock": "npm run hive -- lock",
    "hive:gate": "npm run hive -- gate",
    "hive:check": "npm run hive -- check",
    "hive:health": "bash \"$BEEHIVE_PATH/bin/hive-health.sh\"",
    "hive:telemetry": "bash \"$BEEHIVE_PATH/bin/hive-telemetry.sh\"",
    "hive:insight": "npm run hive -- insight",
    "hive:view": "bash \"$BEEHIVE_PATH/bin/hive-view.sh\"",
    "hive:session:gemini": "npm run hive -- session-start gemini",
    "hive:session:claude": "npm run hive -- session-start claude",
    "hive:session:copilot": "npm run hive -- session-start copilot",
    "hive:session:end:gemini": "npm run hive -- session-end gemini",
    "hive:session:state": "npm run hive -- session-update",
    "gemini:po:hive": "npm run hive -- session-start gemini --role po-hive",
    "gemini:po:produto": "npm run hive -- session-start gemini --role po-produto",
    "gemini:projetista": "npm run hive -- session-start gemini --role projetista",
    "gemini:coordenador": "npm run hive -- session-start gemini --role coordenador",
    "squad:bridge": "bash \"$HIVE_HOME/.agile-squad/framework/squad-bridge.sh\"",
    "squad:cost": "bash \"$BEEHIVE_PATH/bin/hive-cost.sh\"",
    "squad:cost:all": "npm run squad:cost -- --all",
    "squad:cost:log": "npm run squad:cost -- --log",
    "squad:next": "bash \"$BEEHIVE_PATH/bin/hive-next.sh\"",
    "po:demand": "bash \"$BEEHIVE_PATH/bin/hive-po-demand.sh\"",
    "setup": "bash \"$HIVE_HOME/.agile-squad/framework/setup.sh\""
  },
  "engines": {
    "node": ">=24"
  }
}
