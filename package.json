{
  "name": "hive",
  "version": "1.0.0",
  "private": true,
  "description": "Hive OS - Framework de Inteligência Simbiótica para Orquestração de Squads",
  "homepage": "https://github.com/marcio012/hive#readme",
  "bugs": {
    "url": "https://github.com/marcio012/hive/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marcio012/hive.git"
  },
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "// --- 🏭 FÁBRICA: ORQUESTRAÇÃO E GESTÃO (HIVE OS) ---": "",
    "setup": "bash .agile-squad/proxy.sh setup",
    "squad:next": "bash .agile-squad/proxy.sh squad:next",
    "squad:gate": "bash .agile-squad/proxy.sh hive:gate",
    "squad:telemetry": "bash .agile-squad/proxy.sh hive:telemetry",
    "squad:cost": "bash .agile-squad/proxy.sh squad:cost",
    "squad:cost:all": "bash .agile-squad/proxy.sh squad:cost:all",
    "squad:cost:log": "bash .agile-squad/proxy.sh squad:cost:log",
    "build": "npm run squad:orchestrator:build",
    "check:types": "npm run squad:orchestrator:check:types",

    "// --- 🤖 FÁBRICA: SESSÕES E PAPÉIS (HIVE OS) ---": "",
    "gemini:po:hive": "bash .agile-squad/proxy.sh gemini:po:hive",
    "gemini:projetista": "bash .agile-squad/proxy.sh gemini:projetista",
    "gemini:coordenador": "bash .agile-squad/proxy.sh gemini:coordenador",
    "gemini:raw": "bash .agile-squad/proxy.sh gemini:raw",
    "squad:session:claude": "bash .agile-squad/proxy.sh hive:session:claude",
    "squad:session:gemini": "bash .agile-squad/proxy.sh hive:session:gemini",
    "squad:session:copilot": "bash .agile-squad/proxy.sh hive:session:copilot",
    "squad:session:copilot:hive": "bash .agile-squad/proxy.sh hive:session:copilot:hive",
    "squad:session:end:gemini": "bash .agile-squad/proxy.sh hive:session:end:gemini",

    "// --- 🛠️ FÁBRICA: INFRAESTRUTURA E GOVERNANÇA (HIVE OS) ---": "",
    "squad:bridge": "bash .agile-squad/proxy.sh squad:bridge",
    "squad:inbox": "bash .agile-squad/proxy.sh hive:inbox",
    "squad:inbox:lint": "node scripts/inbox-lint.js",
    "squad:inbox:archive": "node scripts/inbox-archive.js",
    "inbox:archive:dry": "bash beehive/bin/hive-inbox.sh archive-dry-run",
    "inbox:archive:faixa-a": "bash beehive/bin/hive-inbox.sh archive-faixa-a",
    "hive:error:set": "node scripts/hive-error-state.js set",
    "hive:error:clear": "node scripts/hive-error-state.js clear",
    "hive:error:read": "node scripts/hive-error-state.js read",
    "hive:guard:check": "node scripts/hive-action-guard.js",
    "squad:lock:acquire": "bash .agile-squad/proxy.sh hive lock set",
    "squad:lock:release": "bash .agile-squad/proxy.sh hive lock release",
    "squad:lock:assert": "bash .agile-squad/proxy.sh hive lock check",
    "squad:orchestrator": "node beehive/apps/orchestrator/dist/index.js",
    "squad:orchestrator:build": "npm --prefix beehive/apps/orchestrator run build",
    "squad:orchestrator:check:types": "npm --prefix beehive/apps/orchestrator run check:types",
    "squad:orchestrator:start": "cd beehive/apps/orchestrator && npx pm2 start dist/index.js --name hive-orchestrator",
    "squad:orchestrator:stop": "cd beehive/apps/orchestrator && npx pm2 stop hive-orchestrator",
    "squad:orchestrator:status": "cd beehive/apps/orchestrator && npx pm2 status hive-orchestrator",
    "squad:tasks": "node scripts/tasks-list.js",
    "squad:orchestrator:pause": "node -e \"const fs=require('fs');const p='.hive-agent/orchestrator-state.json';const st=fs.existsSync(p)?JSON.parse(fs.readFileSync(p,'utf8')):{status:'idle',currentItem:null,pauseReason:null,consecutiveFailures:0,processedEntries:[],updatedAt:new Date().toISOString()};st.status='paused';st.pauseReason=process.argv[1]||'manual';st.updatedAt=new Date().toISOString();fs.writeFileSync(p,JSON.stringify(st,null,2)+'\\n');\"",
    "hive:ui": "npm --prefix beehive/apps/hive-ui run dev",
    "hive:ui:back": "npm --prefix beehive/apps/hive-ui/backend run start:dev",
    "hive:ui:front": "npm --prefix beehive/apps/hive-ui/frontend run dev",

    "// --- 📦 PRODUTO: GESTÃO E VALOR (TENANT OS) ---": "",
    "gemini:po:produto": "bash .agile-squad/proxy.sh gemini:po:produto",
    "po:demand": "bash .agile-squad/proxy.sh po:demand",

    "// --- 🚀 PRODUTO: EXECUÇÃO (TENANT OS) ---": "",
    "squad:session:copilot:tos": "bash .agile-squad/proxy.sh hive:session:copilot:tos"
  },
  "engines": {
    "node": "24.7.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
